@model RestaurantOrderingSystem.Models.MenuItem
@{
    ViewData["Title"] = "Delete Meal";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
        --surface: #141414;
        --panel: #1c1c1e;
        --card: #242428;
        --border: #2e2e32;
        --accent: #e8b86d;
        --muted: #6b6b75;
        --success: #3ecf8e;
        --danger: #ff5c5c;
        --text: #e8e8ec;
        --subtext: #9a9aa8;
    }

    body {
        background: var(--surface);
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
    }

    .adm-topbar {
        background: var(--panel);
        border-bottom: 1px solid var(--border);
        padding: 1.1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .adm-logo {
        font-family: 'Playfair Display', serif;
        font-size: 1.35rem;
        color: var(--accent);
    }

        .adm-logo span {
            color: var(--text);
            font-size: .85rem;
            font-family: 'DM Sans', sans-serif;
            opacity: .45;
            margin-left: .6rem;
            font-weight: 300;
        }

    .del-shell {
        padding: 3rem 1.5rem;
        max-width: 640px;
        margin: 0 auto;
    }

    .adm-crumb {
        font-size: .78rem;
        color: var(--muted);
        margin-bottom: 2rem;
    }

        .adm-crumb a {
            color: var(--accent);
            text-decoration: none;
        }

            .adm-crumb a:hover {
                text-decoration: underline;
            }

        .adm-crumb .sep {
            margin: 0 .5rem;
            opacity: .4;
        }

    /* ── Warning banner ── */
    .danger-banner {
        background: rgba(255,92,92,.08);
        border: 1px solid rgba(255,92,92,.25);
        border-radius: 16px;
        padding: 1.5rem 1.8rem;
        display: flex;
        align-items: flex-start;
        gap: 1.1rem;
        margin-bottom: 1.5rem;
    }

    .danger-icon-wrap {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        background: rgba(255,92,92,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
        color: var(--danger);
    }

    .danger-banner h5 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--danger);
        margin: 0 0 .3rem;
    }

    .danger-banner p {
        font-size: .83rem;
        color: var(--subtext);
        margin: 0;
        line-height: 1.5;
    }

    /* ── Meal detail card ── */
    .meal-detail-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 16px 48px rgba(0,0,0,.45);
        margin-bottom: 1.5rem;
    }

    .meal-detail-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
    }

    .meal-detail-body {
        padding: 1.8rem 2rem;
    }

    .meal-category {
        display: inline-block;
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        background: rgba(232,184,109,.12);
        color: var(--accent);
        padding: .25rem .75rem;
        border-radius: 20px;
        margin-bottom: 1rem;
        border: 1px solid rgba(232,184,109,.22);
    }

    .meal-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.55rem;
        color: var(--text);
        margin-bottom: .5rem;
    }

    .meal-desc {
        font-size: .85rem;
        color: var(--subtext);
        line-height: 1.6;
        margin-bottom: 1.2rem;
    }

    /* ── Detail row ── */
    .detail-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: .7rem 0;
        border-bottom: 1px solid var(--border);
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-key {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--muted);
    }

    .detail-val {
        font-size: .9rem;
        font-weight: 500;
        color: var(--text);
    }

        .detail-val.price {
            color: var(--success);
            font-size: 1.1rem;
            font-weight: 700;
        }

    /* ── Confirmation note ── */
    .confirm-note {
        font-size: .8rem;
        color: var(--subtext);
        margin-bottom: 1.5rem;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.2rem;
    }

        .confirm-note strong {
            color: var(--danger);
        }

    /* ── Buttons ── */
    .btn-danger-del {
        background: var(--danger);
        color: #fff;
        font-size: .9rem;
        font-weight: 700;
        padding: .85rem 2.2rem;
        border-radius: 12px;
        border: none;
        cursor: pointer;
        letter-spacing: .3px;
        transition: opacity .18s, transform .18s, box-shadow .18s;
        display: inline-flex;
        align-items: center;
        gap: .55rem;
    }

        .btn-danger-del:hover {
            opacity: .88;
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(255,92,92,.35);
        }

    .btn-cancel {
        background: transparent;
        border: 1.5px solid var(--border);
        color: var(--subtext);
        font-size: .88rem;
        font-weight: 500;
        padding: .82rem 1.8rem;
        border-radius: 12px;
        text-decoration: none;
        transition: border-color .18s, color .18s;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
    }

        .btn-cancel:hover {
            border-color: #555;
            color: var(--text);
        }

    /* ── TempData error ── */
    .alert-adm {
        background: rgba(255,92,92,.08);
        border: 1px solid rgba(255,92,92,.25);
        border-radius: 12px;
        padding: 1rem 1.2rem;
        font-size: .85rem;
        color: var(--danger);
        margin-bottom: 1.5rem;
    }
</style>

<!-- Topbar -->
<div class="adm-topbar">
    <div class="adm-logo">&#9670; Saveur <span>Admin Console</span></div>
</div>

<div class="del-shell">

    <!-- Breadcrumb -->
    <div class="adm-crumb">
        <a asp-action="Index">Menu Management</a>
        <span class="sep">›</span>
        Delete Meal
    </div>

    <!-- TempData error -->
    @if (TempData["Error"] != null)
    {
        <div class="alert-adm">&#9888;&nbsp; @TempData["Error"]</div>
    }

    <!-- Warning banner -->
    <div class="danger-banner">
        <div class="danger-icon-wrap">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                <line x1="12" y1="9" x2="12" y2="13" />
                <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
        </div>
        <div>
            <h5>You are about to delete a menu item</h5>
            <p>This action is permanent and cannot be undone. All data associated with this item will be removed from the system.</p>
        </div>
    </div>

    <!-- Meal detail card -->
    <div class="meal-detail-card">
        <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?w=800&auto=format&fit=crop"
             class="meal-detail-img" alt="@Model.Name">
        <div class="meal-detail-body">
            <div class="meal-category">@Model.Category</div>
            <div class="meal-name">@Model.Name</div>
            <div class="meal-desc">@Model.Description</div>

            <div class="detail-row">
                <span class="detail-key">Item ID</span>
                <span class="detail-val">#@Model.MenuItemId</span>
            </div>
            <div class="detail-row">
                <span class="detail-key">Category</span>
                <span class="detail-val">@Model.Category</span>
            </div>
            <div class="detail-row">
                <span class="detail-key">Price</span>
                <span class="detail-val price">EGP @Model.Price.ToString("0.00")</span>
            </div>
        </div>
    </div>

    <!-- Confirm note -->
    <div class="confirm-note">
        &#128274;&nbsp; Deleting <strong>"@Model.Name"</strong> will permanently remove it from the menu. If this item is associated with existing orders, deletion will be blocked automatically.
    </div>

    <!-- Form -->
    <form asp-action="Delete" asp-route-id="@Model.MenuItemId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="MenuItemId" />

        <div class="d-flex align-items-center gap-3">
            <button type="submit" class="btn-danger-del">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                    <path d="M10 11v6M14 11v6" />
                    <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
                </svg>
                Yes, Delete Permanently
            </button>
            <a asp-action="Index" class="btn-cancel">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7" /></svg>
                Keep Meal
            </a>
        </div>
    </form>

</div>
