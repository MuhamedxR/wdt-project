@model RestaurantOrderingSystem.Models.PaginatedList<RestaurantOrderingSystem.Models.MenuItem>

@{
    ViewData["Title"] = "Menu";

    var role =
        Context.Session.GetString("Role");
}
@if (role == "Admin")
{
    <!-- SEARCH BAR -->
    <div class="row mb-4">

        <div class="col-md-12">

            <input type="text"
                   id="searchInput"
                   class="form-control form-control-lg shadow-sm"
                   placeholder="Search meals or categories..." />

        </div>

    </div>
    <div class="container-fluid mt-4">

        <!-- PAGE HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>

                <h1 class="fw-bold mb-1">

                    Menu Management

                </h1>

                <p class="text-muted mb-0">

                    Manage restaurant meals and categories

                </p>

            </div>

            <a asp-action="Create"
               class="btn btn-dark btn-lg px-4">

                + Add New Meal

            </a>

        </div>

        <!-- STATS -->
        <div class="row mb-4">

            <div class="col-md-4">

                <div class="card border-0 shadow-sm rounded-4">

                    <div class="card-body">

                        <h6 class="text-muted">

                            Total Meals

                        </h6>

                        <h2 class="fw-bold">

                            @Model.Count()

                        </h2>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card border-0 shadow-sm rounded-4">

                    <div class="card-body">

                        <h6 class="text-muted">

                            Categories

                        </h6>

                        <h2 class="fw-bold">

                            @Model.Select(m => m.Category).Distinct().Count()

                        </h2>

                    </div>

                </div>

            </div>

            <div class="col-md-4">

                <div class="card border-0 shadow-sm rounded-4">

                    <div class="card-body">

                        <h6 class="text-muted">

                            Average Price

                        </h6>

                        <h2 class="fw-bold text-success">

                            EGP @Model.Average(m => m.Price).ToString("0")

                        </h2>

                    </div>

                </div>

            </div>

        </div>

        <!-- MENU GRID -->
        <div class="row"
             id="mealsContainer">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4 meal-card">


                    <!-- IMAGE -->
                    <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=1200&auto=format&fit=crop"
                         class="card-img-top"
                         style="height:230px; object-fit:cover;">

                    <div class="card-body d-flex flex-column p-4">

                        <!-- CATEGORY -->
                        <span class="badge bg-dark mb-3 align-self-start">

                            @item.Category

                        </span>

                        <!-- NAME -->
                        <h3 class="fw-bold mb-2">

                            @item.Name

                        </h3>

                        <!-- DESCRIPTION -->
                        <p class="text-muted flex-grow-1">

                            @item.Description

                        </p>

                        <!-- PRICE -->
                        <h3 class="fw-bold text-success mb-4">

                            EGP @item.Price

                        </h3>

                        <!-- ACTIONS -->
                        <div class="d-flex gap-2">

                            <a asp-action="Edit"
                               asp-route-id="@item.MenuItemId"
                               class="btn btn-dark w-50">

                                Edit

                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.MenuItemId"
                               class="btn btn-outline-danger w-50">

                                Delete

                            </a>

                        </div>

                    </div>

                </div>

            }

        </div>

    </div>
}
else
{
    <div class="container-fluid mt-4">

        <!-- SEARCH BAR -->
        <div class="row mb-4">

            <div class="row mb-4 align-items-center">

                <!-- SEARCH -->
                <div class="col-md-8">

                    <input type="text"
                           id="searchInput"
                           class="form-control form-control-lg shadow-sm"
                           placeholder="Search meals or categories...">

                </div>

                <!-- SORT -->
                <div class="col-md-4">

                    <select id="sortSelect"
                            class="form-select form-select-lg shadow-sm">

                        <option value="default">

                            Sort By

                        </option>

                        <option value="low">

                            Price: Low To High

                        </option>

                        <option value="high">

                            Price: High To Low

                        </option>

                        <option value="name">

                            Name A-Z

                        </option>

                    </select>

                </div>

            </div>

        </div>

        <div class="row">

            <!-- Categories Sidebar -->
            <div class="col-md-2">

                <div class="card shadow-sm position-sticky"
                     style="
                                                                        top:20px;
                                                                        max-height:85vh;
                                                                        overflow-y:auto;
                                                                     ">

                    <div class="card-header bg-dark text-white">

                        Categories

                    </div>

                    <div class="list-group list-group-flush">

                        <a asp-action="Index"
                           class="list-group-item list-group-item-action">

                            All

                        </a>

                        @foreach (var category in ViewBag.Categories)
                        {
                            <a asp-action="Index"
                               asp-route-category="@category"
                               class="list-group-item list-group-item-action">

                                @category

                            </a>
                        }

                    </div>

                </div>

            </div>

            <!-- Menu Items -->
            <div class="col-md-7">

                <div class="row"
                     id="mealsContainer">

                    @foreach (var item in Model)
                    {
                        <div class="col-md-6 mb-4 meal-card"
                             data-search="@($"{item.Name} {item.Category} {item.Description}".ToLower())"
                             data-price="@item.Price"
                             data-name="@item.Name.ToLower()">
                            <div class="card h-100 shadow-sm">

                                <div class="card-body d-flex flex-column">

                                    <h4 class="card-title">

                                        @item.Name

                                    </h4>

                                    <h6 class="text-success mb-3">

                                        @item.Price EGP

                                    </h6>

                                    <p class="card-text">

                                        @item.Description

                                    </p>

                                    <span class="badge bg-secondary mb-3">

                                        @item.Category

                                    </span>

                                    <div class="mt-auto">

                                        <a asp-action="Details"
                                           asp-route-id="@item.MenuItemId"
                                           class="btn btn-info btn-sm">

                                            Details

                                        </a>

                                        <a asp-controller="Cart"
                                           asp-action="AddToCart"
                                           asp-route-id="@item.MenuItemId"
                                           class="btn btn-success btn-sm">

                                            Add To Cart

                                        </a>

                                    </div>

                                </div>

                            </div>

                        </div>
                    }

                </div>

            </div>

            <!-- Cart Sidebar -->
            <div class="col-md-3">

                <div class="card shadow-sm">

                    <div class="card-header bg-success text-white">

                        Your Cart

                    </div>

                    <div class="card-body">

                        @{
                            var cart =
                            ViewBag.Cart as
                            List<RestaurantOrderingSystem.Models.CartItem>;
                        }

                        @if (cart == null || !cart.Any())
                        {
                            <p>
                                Your Cart Is Empty
                            </p>
                        }

                        else
                        {
                            @foreach (var item in cart)
                            {
                                <div class="border-bottom mb-2 pb-2">

                                    <h6>

                                        @item.Name

                                    </h6>

                                    <small>

                                        Quantity:
                                        @item.Quantity

                                    </small>

                                    <br />

                                    <small class="text-success">

                                        @item.Total EGP

                                    </small>

                                </div>
                            }

                            <hr />

                            <h5>

                                Total:
                                @cart.Sum(c => c.Total) EGP

                            </h5>

                            <a asp-controller="Cart"
                               asp-action="Index"
                               class="btn btn-success w-100 mt-2">

                                Go To Cart

                            </a>

                            <a asp-controller="Cart"
                               asp-action="Checkout"
                               class="btn btn-dark w-100 mt-2">

                                Checkout

                            </a>

                            <a asp-controller="Cart"
                               asp-action="ClearCart"
                               class="btn btn-danger w-100 mt-2">

                                Clear Cart

                            </a>
                        }

                    </div>

                </div>

            </div>

        </div>



        @{
            var prevDisabled =
            !Model.HasPreviousPage
            ? "disabled"
            : "";

            var nextDisabled =
            !Model.HasNextPage
            ? "disabled"
            : "";
        }

        <div class="d-flex justify-content-center mt-4">

            <nav>

                <ul class="pagination shadow-sm">

                    <!-- PREVIOUS -->

                    <li class="page-item @prevDisabled">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pageNumber="@(Model.PageIndex - 1)"
                           asp-route-category="@ViewBag.CurrentCategory"
                           asp-route-search="@ViewBag.CurrentSearch"
                           asp-route-sort="@ViewBag.CurrentSort">

                            Previous

                        </a>

                    </li>

                    <!-- PAGE NUMBERS -->
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.PageIndex == i ? "active" : "")">

                            <a class="page-link"
                               asp-action="Index"
                               asp-route-pageNumber="@i"
                               asp-route-category="@ViewBag.CurrentCategory"
                               asp-route-search="@ViewBag.CurrentSearch"
                               asp-route-sort="@ViewBag.CurrentSort">

                                @i

                            </a>

                        </li>
                    }

                    <!-- NEXT -->

                    <li class="page-item @nextDisabled">

                        <a class="page-link"
                           asp-action="Index"
                           asp-route-pageNumber="@(Model.PageIndex + 1)"
                           asp-route-category="@ViewBag.CurrentCategory"
                           asp-route-search="@ViewBag.CurrentSearch"
                           asp-route-sort="@ViewBag.CurrentSort">

                            Next

                        </a>

                    </li>

                </ul>

            </nav>
        </div>
    </div>
}
<script>

    const searchInput =
        document.getElementById("searchInput");

    const meals =
        document.querySelectorAll(".meal-card");

    searchInput.addEventListener("input", function () {

        const value =
            this.value.toLowerCase();

        meals.forEach(meal => {

            const text =
                meal.innerText.toLowerCase();

            if (text.includes(value))
            {
                meal.style.display = "";
            }
            else
            {
                meal.style.display = "none";
            }

        });

    });

    //Sort
      const sortSelect =
        document.getElementById("sortSelect");

    const mealsContainer =
        document.getElementById("mealsContainer");

    sortSelect.addEventListener("change", function () {

        const cards =
            Array.from(document.querySelectorAll(".meal-card"));

        const value =
            this.value;

        cards.sort((a, b) => {

            const priceA =
                parseFloat(a.dataset.price);

            const priceB =
                parseFloat(b.dataset.price);

            const nameA =
                a.dataset.name;

            const nameB =
                b.dataset.name;

            if (value === "low")
            {
                return priceA - priceB;
            }

            if (value === "high")
            {
                return priceB - priceA;
            }

            if (value === "name")
            {
                return nameA.localeCompare(nameB);
            }

            return 0;

        });

        mealsContainer.innerHTML = "";

        cards.forEach(card => {

            mealsContainer.appendChild(card);

        });

    });
</script>

<style>

    .card::-webkit-scrollbar {
        width: 6px;
    }

    .card::-webkit-scrollbar-thumb {
        background: #198754;
        border-radius: 20px;
    }

</style>