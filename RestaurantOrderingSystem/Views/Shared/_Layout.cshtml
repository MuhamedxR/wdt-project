@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var isAdmin = role == "Admin";
    var username = HttpContextAccessor.HttpContext.Session.GetString("Name");
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Top Chef</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --primary: #111827;
            --accent: #16a34a;
        }
    </style>
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3 d-flex align-items-center" href="/">
                <img src="~/images/logo.png" alt="Top Chef" style="height:52px;" class="me-2" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                @if (isAdmin)
                {
                    <!-- Admin Navbar -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-gauge"></i> Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Orders" asp-action="Index"><i class="fa-solid fa-list"></i> Orders</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="MenuItems" asp-action="Index"><i class="fa-solid fa-utensils"></i> Menu</a></li>
                    </ul>
                }
                else
                {
                    <!-- Customer Navbar -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="MenuItems" asp-action="Index">Menu</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>
                    </ul>
                }

                <ul class="navbar-nav ms-auto align-items-center gap-3">
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                            <i class="fa-solid fa-cart-shopping fa-xl"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cartCount">
                                @((ViewBag.Cart as List<RestaurantOrderingSystem.Models.CartItem>)?.Count ?? 0)
                            </span>
                        </a>
                    </li>

                    @if (username != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                                <i class="fa-solid fa-user-circle fa-xl me-2"></i>
                                @username
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Logout">Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light px-4">Login</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Register" class="btn btn-success px-4">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-shrink-0">
        @RenderBody()
    </main>

    <!-- Modern Footer -->
    <footer class="bg-dark text-light py-5 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h4 class="fw-bold mb-3">
                        <img src="~/images/logo.png" alt="Top Chef" style="height:35px;" class="me-2" />
                        TOP CHEF
                    </h4>
                    <p class="text-light-50">Premium Restaurant Experience with Fast Delivery</p>
                </div>
                <div class="col-md-2 col-6 mb-4">
                    <h6 class="fw-bold mb-3">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="/" class="text-light-50 text-decoration-none">Home</a></li>
                        <li><a asp-controller="MenuItems" asp-action="Index" class="text-light-50 text-decoration-none">Menu</a></li>
                        <li><a href="#" class="text-light-50 text-decoration-none">Track Order</a></li>
                    </ul>
                </div>
                <div class="col-md-3 col-6 mb-4">
                    <h6 class="fw-bold mb-3">Contact</h6>
                    <p class="text-light-50 mb-1">📍 North Sinai, Egypt</p>
                    <p class="text-light-50">📞 +20 123 456 7890</p>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-bold mb-3">Follow Us</h6>
                    <div class="fs-3">
                        <a href="#" class="text-light me-3"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-light me-3"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-light"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4 border-secondary">
            <div class="text-center text-light-50 small">
                © @DateTime.Now.Year Top Chef Restaurant. All Rights Reserved.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>