@model List<RestaurantOrderingSystem.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-4">

    <h1 class="mb-4">
        Shopping Cart
    </h1>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">

            <h4>
                Your Cart Is Empty
            </h4>

            <a asp-controller="MenuItems"
               asp-action="Index"
               class="btn btn-primary mt-2">

                Back To Menu

            </a>

        </div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">

            <thead class="table-dark">

                <tr>

                    <th>Name</th>

                    <th>Price</th>

                    <th>Quantity</th>

                    <th>Total</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @item.Name
                        </td>

                        <td>
                            @item.Price EGP
                        </td>

                        <td>
                            @item.Quantity
                        </td>

                        <td>
                            @item.Total EGP
                        </td>

                        <td>

                            <a asp-action="Increase"
                               asp-route-id="@item.MenuItemId"
                               class="btn btn-success btn-sm">

                                +

                            </a>

                            <a asp-action="Decrease"
                               asp-route-id="@item.MenuItemId"
                               class="btn btn-warning btn-sm">

                                -

                            </a>

                            <a asp-action="Remove"
                               asp-route-id="@item.MenuItemId"
                               class="btn btn-danger btn-sm">

                                Remove

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <div class="d-flex justify-content-between align-items-center mt-4">

            <h3>

                Cart Total :
                @Model.Sum(i => i.Total) EGP

            </h3>

            <div>

                <a asp-controller="MenuItems"
                   asp-action="Index"
                   class="btn btn-secondary">

                    Continue Shopping

                </a>

                <a asp-action="Checkout"
                   class="btn btn-primary">

                    Checkout

                </a>

            </div>

        </div>
    }

</div>