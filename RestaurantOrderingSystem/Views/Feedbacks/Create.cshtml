@model RestaurantOrderingSystem.Models.Feedback

@{
    ViewData["Title"] = "Add Feedback";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-7">

            <div class="card shadow-sm border-0">

                <div class="card-body p-4">

                    <h2 class="fw-bold mb-3">

                        Add Feedback

                    </h2>

                    <p class="text-muted mb-4">

                        Share your experience with your order

                    </p>

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <!-- Hidden OrderId -->
                        <input type="hidden"
                               asp-for="OrderId" />

                        <!-- Comment -->
                        <div class="mb-3">

                            <label asp-for="Comment"
                                   class="form-label fw-semibold">

                                Comment

                            </label>

                            <textarea asp-for="Comment"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Write your feedback here...">
                            </textarea>

                            <span asp-validation-for="Comment"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Rating -->
                        <div class="mb-4">

                            <label asp-for="Rating"
                                   class="form-label fw-semibold">

                                Rating

                            </label>

                            <select asp-for="Rating"
                                    class="form-select">

                                <option value="">

                                    -- Select Rating --

                                </option>

                                <option value="1">1 - Very Bad</option>
                                <option value="2">2 - Bad</option>
                                <option value="3">3 - Average</option>
                                <option value="4">4 - Good</option>
                                <option value="5">5 - Excellent</option>

                            </select>

                            <span asp-validation-for="Rating"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-success">

                                Submit Feedback

                            </button>

                            <a asp-controller="Orders"
                               asp-action="Index"
                               class="btn btn-outline-dark">

                                Back To Orders

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}