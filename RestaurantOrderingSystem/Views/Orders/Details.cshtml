@model RestaurantOrderingSystem.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<h1 class="mb-4">Order Details</h1>

<div class="card shadow p-4 mb-4">

    <h4 class="mb-3">Order Information</h4>

    <dl class="row">

        <dt class="col-sm-3">
            Order Date
        </dt>

        <dd class="col-sm-9">
            @Model.OrderDate
        </dd>


        <dt class="col-sm-3">
            Order Type
        </dt>

        <dd class="col-sm-9">
            @Model.OrderType
        </dd>
        <dt class="col-sm-3">
            Status
        </dt>

        <dd class="col-sm-9">
            @Model.Status
        </dd>

        <dt class="col-sm-3">
            Customer Phone
        </dt>

        <dd class="col-sm-9">
            @Model.CustomerPhone
        </dd>


        @if (Model.OrderType == "Delivery")
        {
            <dt class="col-sm-3">
                Delivery Address
            </dt>

            <dd class="col-sm-9">
                @Model.DeliveryAddress
            </dd>

            <dt class="col-sm-3">
                Delivery Employee
            </dt>

            <dd class="col-sm-9">
                @Model.AssignedEmployeeName
            </dd>
        }


        <dt class="col-sm-3">
            Payment Method
        </dt>

        <dd class="col-sm-9">
            @Model.PaymentMethod
        </dd>


        <dt class="col-sm-3">
            Total Amount
        </dt>

        <dd class="col-sm-9 fw-bold text-success">
            @Model.TotalAmount EGP
        </dd>


        <dt class="col-sm-3">
            Customer
        </dt>

        <dd class="col-sm-9">
            @Model.User.Name
        </dd>

    </dl>

</div>


<!-- Order Items -->

<div class="card shadow p-4">

    <h4 class="mb-3">Ordered Items</h4>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>
                <th>Menu Item</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Total</th>
            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.OrderItems)
            {
                <tr>

                    <td>
                        @item.MenuItem.Name
                    </td>

                    <td>
                        @item.Quantity
                    </td>

                    <td>
                        @item.UnitPrice EGP
                    </td>

                    <td>
                        @(item.Quantity* item.UnitPrice) EGP
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>


<div class="mt-4">

    @if (Context.Session.GetString("Role") == "Admin")
    {
        <a asp-action="Edit"
           asp-route-id="@Model.OrderId"
           class="btn btn-warning">
            Edit
        </a>
    }

    <a asp-action="Index"
       class="btn btn-secondary">
        Back To Orders
    </a>

</div>