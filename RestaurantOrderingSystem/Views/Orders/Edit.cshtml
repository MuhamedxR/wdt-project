@model RestaurantOrderingSystem.Models.Order

@using RestaurantOrderingSystem.Models

@{
    ViewData["Title"] = "Manage Order";
}

<div class="container mt-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-1">

                Manage Order #@Model.OrderId

            </h1>

            <p class="text-muted mb-0">

                Update order status and assign employees

            </p>

        </div>

        <a asp-action="Index"
           class="btn btn-outline-dark">

            Back To Orders

        </a>

    </div>

    <div class="row">

        <!-- CUSTOMER INFO -->
        <div class="col-lg-4 mb-4">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4">

                        Customer Information

                    </h4>

                    <div class="mb-3">

                        <small class="text-muted d-block">

                            Customer Name

                        </small>

                        <strong>

                            @Model.User?.Name

                        </strong>

                    </div>

                    <div class="mb-3">

                        <small class="text-muted d-block">

                            Phone Number

                        </small>

                        <strong>

                            @Model.CustomerPhone

                        </strong>

                    </div>

                    <div class="mb-3">

                        <small class="text-muted d-block">

                            Delivery Address

                        </small>

                        <strong>

                            @(string.IsNullOrEmpty(Model.DeliveryAddress)
                                                        ? "Not Provided"
                                                        : Model.DeliveryAddress)

                        </strong>

                    </div>

                    <div class="mb-3">

                        <small class="text-muted d-block">

                            Payment Method

                        </small>

                        <strong>

                            @Model.PaymentMethod

                        </strong>

                    </div>

                    <div class="mb-3">

                        <small class="text-muted d-block">

                            Order Date

                        </small>

                        <strong>

                            @Model.OrderDate.ToString("dd MMM yyyy - hh:mm tt")

                        </strong>

                    </div>

                    <div>

                        <small class="text-muted d-block">

                            Total Amount

                        </small>

                        <h3 class="fw-bold text-success">

                            EGP @Model.TotalAmount

                        </h3>

                    </div>

                </div>

            </div>

        </div>

        <!-- MANAGE ORDER -->
        <div class="col-lg-8 mb-4">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4">

                        Order Management

                    </h4>

                    <form asp-action="Edit"
                          method="post">

                        <input type="hidden"
                               asp-for="OrderId" />

                        <div class="row">

                            <!-- STATUS -->
                            <div class="col-md-6 mb-4">

                                <label asp-for="Status"
                                       class="form-label fw-semibold">

                                    Order Status

                                </label>

                                <select asp-for="Status"
                                        class="form-select form-select-lg">

                                    <option value="Pending">

                                        Pending

                                    </option>

                                    <option value="Preparing">

                                        Preparing

                                    </option>

                                    <option value="Delivered">

                                        Delivered

                                    </option>

                                    <option value="Cancelled">

                                        Cancelled

                                    </option>

                                </select>

                            </div>

                            <!-- EMPLOYEE -->
                            <div class="col-md-6 mb-4">

                                <label asp-for="AssignedEmployeeName"
                                       class="form-label fw-semibold">

                                    Assigned Employee

                                </label>

                                <input asp-for="AssignedEmployeeName"
                                       class="form-control form-control-lg"
                                       placeholder="Enter Employee Name" />

                            </div>

                        </div>

                        <button type="submit"
                                class="btn btn-dark btn-lg px-5">

                            Save Changes

                        </button>

                    </form>

                </div>

            </div>

            <!-- ORDER ITEMS -->
            <div class="card border-0 shadow-sm rounded-4 mt-4">

                <div class="card-body p-4">

                    <h4 class="fw-bold mb-4">

                        Order Items

                    </h4>

                    <div class="table-responsive">

                        <table class="table align-middle">

                            <thead>

                                <tr>

                                    <th>Product</th>

                                    <th>Quantity</th>

                                    <th>Unit Price</th>

                                    <th>Total</th>

                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>

                                        <td>

                                            @item.MenuItem?.Name

                                        </td>

                                        <td>

                                            @item.Quantity

                                        </td>

                                        <td>

                                            EGP @item.UnitPrice

                                        </td>

                                        <td class="fw-bold">

                                            EGP @(item.Quantity* item.UnitPrice)

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>