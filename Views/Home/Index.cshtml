@{
    ViewData["Title"] = "Home";
}

<!-- HERO SLIDER -->
<div id="heroCarousel" class="carousel slide mb-5 shadow-lg rounded-4 overflow-hidden" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height:400px; object-fit:cover;" alt="Delicious Meals">
            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-4">
                <h1 class="display-4 fw-bold">Welcome to Zacks Restaurant</h1>
                <p class="lead">Taste the best fried chicken and more!</p>
                <a asp-controller="MenuItems" asp-action="Index" class="btn btn-warning btn-lg shadow">Order Now <i class="fa-solid fa-arrow-right"></i></a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1519864600265-abb23847ef2c?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height:400px; object-fit:cover;" alt="Family Meals">
            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-4">
                <h1 class="display-5 fw-bold">Family Meals &amp; Combos</h1>
                <p class="lead">Perfect for sharing with friends and family.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1464306076886-debca5e8a6b0?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" style="height:400px; object-fit:cover;" alt="Fresh Ingredients">
            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-4">
                <h1 class="display-5 fw-bold">Fresh Ingredients</h1>
                <p class="lead">Quality you can taste in every bite.</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- BEST OFFERS SECTION -->
<section class="mb-5">
    <h2 class="fw-bold text-warning mb-4 text-center">Best Offers</h2>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card offer-card shadow-lg rounded-4 h-100 border-0">
                <img src="https://images.unsplash.com/photo-1502741338009-cac2772e18bc?auto=format&fit=crop&w=600&q=80" class="card-img-top" style="height:200px; object-fit:cover;" alt="Offer 1">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Family Bucket</h5>
                    <p class="card-text">Get 20% off on our famous family bucket. Perfect for sharing!</p>
                    <span class="badge bg-warning text-dark fs-6">EGP 199</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card offer-card shadow-lg rounded-4 h-100 border-0">
                <img src="https://images.unsplash.com/photo-1519864600265-abb23847ef2c?auto=format&fit=crop&w=600&q=80" class="card-img-top" style="height:200px; object-fit:cover;" alt="Offer 2">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Zacks Combo</h5>
                    <p class="card-text">Combo meal with chicken, fries, and a drink at a special price.</p>
                    <span class="badge bg-warning text-dark fs-6">EGP 89</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card offer-card shadow-lg rounded-4 h-100 border-0">
                <img src="https://images.unsplash.com/photo-1464306076886-debca5e8a6b0?auto=format&fit=crop&w=600&q=80" class="card-img-top" style="height:200px; object-fit:cover;" alt="Offer 3">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Student Meal</h5>
                    <p class="card-text">Special meal for students. Show your ID and save big!</p>
                    <span class="badge bg-warning text-dark fs-6">EGP 59</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- POPULAR MEALS SECTION -->
<section class="mb-5">
    <h2 class="fw-bold text-light mb-4 text-center">Popular Meals</h2>
    <div class="row g-4">
        <div class="col-md-3 col-6">
            <div class="card meal-card shadow rounded-4 h-100 border-0">
                <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=400&q=80" class="card-img-top" style="height:150px; object-fit:cover;" alt="Meal 1">
                <div class="card-body text-center">
                    <h6 class="fw-bold">Crispy Fried Chicken</h6>
                    <span class="badge bg-success">EGP 49</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card meal-card shadow rounded-4 h-100 border-0">
                <img src="https://images.unsplash.com/photo-1519864600265-abb23847ef2c?auto=format&fit=crop&w=400&q=80" class="card-img-top" style="height:150px; object-fit:cover;" alt="Meal 2">
                <div class="card-body text-center">
                    <h6 class="fw-bold">Spicy Chicken Wings</h6>
                    <span class="badge bg-success">EGP 39</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card meal-card shadow rounded-4 h-100 border-0">
                <img src="https://images.unsplash.com/photo-1464306076886-debca5e8a6b0?auto=format&fit=crop&w=400&q=80" class="card-img-top" style="height:150px; object-fit:cover;" alt="Meal 3">
                <div class="card-body text-center">
                    <h6 class="fw-bold">Zacks Chicken Burger</h6>
                    <span class="badge bg-success">EGP 59</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card meal-card shadow rounded-4 h-100 border-0">
                <img src="https://images.unsplash.com/photo-1502741338009-cac2772e18bc?auto=format&fit=crop&w=400&q=80" class="card-img-top" style="height:150px; object-fit:cover;" alt="Meal 4">
                <div class="card-body text-center">
                    <h6 class="fw-bold">Loaded Fries</h6>
                    <span class="badge bg-success">EGP 29</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORIES SECTION -->
<section class="mb-5">
    <h2 class="fw-bold text-warning mb-4 text-center">Categories</h2>
    <div class="row g-4 justify-content-center">
        <div class="col-md-2 col-4">
            <div class="category-card bg-dark text-center rounded-4 shadow p-4 h-100 hover-scale">
                <i class="fa-solid fa-drumstick-bite fa-2x text-warning mb-2"></i>
                <div class="fw-bold">Chicken</div>
            </div>
        </div>
        <div class="col-md-2 col-4">
            <div class="category-card bg-dark text-center rounded-4 shadow p-4 h-100 hover-scale">
                <i class="fa-solid fa-burger fa-2x text-warning mb-2"></i>
                <div class="fw-bold">Burgers</div>
            </div>
        </div>
        <div class="col-md-2 col-4">
            <div class="category-card bg-dark text-center rounded-4 shadow p-4 h-100 hover-scale">
                <i class="fa-solid fa-fish fa-2x text-warning mb-2"></i>
                <div class="fw-bold">Seafood</div>
            </div>
        </div>
        <div class="col-md-2 col-4">
            <div class="category-card bg-dark text-center rounded-4 shadow p-4 h-100 hover-scale">
                <i class="fa-solid fa-pepper-hot fa-2x text-warning mb-2"></i>
                <div class="fw-bold">Spicy</div>
            </div>
        </div>
        <div class="col-md-2 col-4">
            <div class="category-card bg-dark text-center rounded-4 shadow p-4 h-100 hover-scale">
                <i class="fa-solid fa-mug-hot fa-2x text-warning mb-2"></i>
                <div class="fw-bold">Drinks</div>
            </div>
        </div>
    </div>
</section>